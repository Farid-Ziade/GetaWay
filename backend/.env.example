# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000

# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173

# ─── Firebase Admin SDK ───────────────────────────────────────────────────────
# Paste the full content of your Firebase service account JSON as a single line.
# Download from: Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"..."}

# ─── OpenAI ───────────────────────────────────────────────────────────────────
# Never expose this key in the frontend. Backend-only.
OPENAI_API_KEY=sk-...

# ─── Google Maps (server-side key — restricted to this backend IP only) ───────
GOOGLE_MAPS_SERVER_KEY=AIza...
